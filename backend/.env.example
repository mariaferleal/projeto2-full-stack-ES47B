PORT=3001
FRONTEND_ORIGIN=http://localhost:5173
JWT_SECRET=troque-esta-chave
JWT_EXPIRES_IN=2h

# HTTPS: gere os certificados locais com "npm run certs" e descomente abaixo
# SSL_KEY_PATH=./certs/localhost-key.pem
# SSL_CERT_PATH=./certs/localhost-cert.pem

# Opção 1: URL completa
DATABASE_URL=postgres://postgres:postgres@localhost:5432/rickandmorty

# Opção 2: variáveis separadas, usadas se DATABASE_URL não for definida
PGHOST=localhost
PGPORT=5432
PGDATABASE=rickandmorty
PGUSER=postgres
PGPASSWORD=postgres
DB_POOL_SIZE=10
CACHE_TTL_MS=60000
